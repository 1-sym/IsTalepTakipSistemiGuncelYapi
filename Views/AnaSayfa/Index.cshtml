@using IsTakipSistemi.Data;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    @model IsTakipSistemi.Models.IsTalepModel
    varlik vari = new varlik();
}
<h1 style="color:brown">Ana Sayfa</h1>


<form id="formKayit" name="formKayit" autocomplete="off">
    @{

    
           <h3>
               Aktif İş Talepleri

        </h3>


       
        
        <div style="float: left; width: 100%; height:30px;  "></div>
        <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
            <thead>
                <tr>
                    <th> </th>
                    <th>Talep Tarihi</th>
                    <th>Güncelleme Tarihi</th>
                    <th>Personel Adı-Soyadı</th>
                    <th>Talep Bilgi</th>
                    <th>Talep Tamamlandı mı?</th>
                    <th>Talep Tamamlanma Oranı</th>

                    <th>Detay</th>
                    <th>
                        Talep İşle
                    </th>
                </tr>
            </thead>
            <tbody>
                @{
                    List<IsTalebiAYRINTI> veri = Model.dokumVerisi.Where(q=>q.talepTamamlandimi==0).ToList();
                    foreach (var satir in veri)
                    {
                        <tr row_id="@satir.talepID.ToString()">
                            <td>
                                <input type="checkbox" class="checkBox"
                                       value="@satir.talepID" />
                            </td>
                            <th>@satir.talepTarihi</th>
                            <th>@satir.guncellemeTarihi</th>
                            <th>@satir.adi @satir.soyadi</th>
                           
                            <th>@satir.talepAyrinti</th>
                            <th>@satir.talepTamamlandimi</th>
                            @{
                                TalepTakipAYRINTI talepDurum = vari.TalepTakipAYRINTIler.Where(q => q.i_talepID == satir.talepID).OrderBy(t => t.tamamlanmaOrani).LastOrDefault();


                                if (talepDurum != null)
                                {
                                    <th>%@talepDurum.tamamlanmaOrani</th>
                                }
                                else
                                {
                                    <th>%0</th>
                                }
                            }

                            <th>@satir.detay</th>
                            <td>
                                <a class="btn btn-outline-secondary btn-sm edit" onclick="kartAc(); return false;" style="color: #ffffff !important; background-color: #ffae00; border-color: #ffae00; " title="Edit">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</form>
<script>
    function kartAc() {
        window.location.href = "/TalepTakip/Kart/";
    }

</script>

