@{

    Layout = "~/Views/Shared/_Layout.cshtml";
@using IsTakipSistemi.Data;
    varlik vari = new varlik();
    List<SelectListItem> kullaniciTuru = new List<SelectListItem>();
    List<KullaniciTuruAYRINTI> hepsi = vari.KullaniciTuruAYRINTIler.ToList();
    for (int i = 0; i < hepsi.Count; i++)
    {
        SelectListItem yeni = new SelectListItem();
        yeni.Text = hepsi[i].kullaniciTuru;
        yeni.Value = hepsi[i].kullaniciTuruID.ToString();
        
        kullaniciTuru.Add(yeni);
    

}
   
    
}
@model IsTakipSistemi.Models.KullaniciModel
<script src="~/assets/js/jquery.dataTables.min.js"></script>
<h1 style="color:brown">Kullanıcı Ekle</h1>
<hr />
<div class="row">
    <div class="col-6">
        <a href="@String.Format("/Kullanici/Index")" class="float-start" style="margin-top:5px; margin-left:5px">
            <i class="fa fa-arrow-left h1 mb-0 text-primary" style="font-size:16px"><span style="margin-left:10px; ">Geri Dön</span></i>
        </a>
    </div></div>
<form id="formKayit" name="formKayit" autocomplete="off">
    <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
        <div class="row">

            <div class="form-group">
                <label for="member-name" class="col-form-label">Ad</label>
                @Html.TextBoxFor(m => m.kartVerisi.adi, new { @class = "form-control", maxlength = "50", placeholder = "Ad" })
            </div>
            <div class="form-group">
                <label for="member-name" class="col-form-label">Soyad</label>
                @Html.TextBoxFor(m => m.kartVerisi.soyadi, new { @class = "form-control", maxlength = "50", placeholder = "Soyad" })
            </div>
            <div class="form-group">
                <label for="member-name" class="col-form-label">TC No</label>
                @Html.TextBoxFor(m => m.kartVerisi.TcNo, new { @class = "form-control", maxlength = "11", placeholder = "TC No" })
            </div>
            <div class="form-group">
                <label for="member-name" class="col-form-label">Telefon</label>
                @Html.TextBoxFor(m => m.kartVerisi.telefon, new { @class = "form-control", maxlength = "11", placeholder = "Telefon" })
            </div>
            <div class="form-group">
                <label for="member-name" class="col-form-label">Şifre</label>
                @Html.TextBoxFor(m => m.kartVerisi.sifre, new { @class = "form-control", minlengt="4", maxlength = "8", placeholder = "Şifre" })
            </div>
           
            <div class="form-group">
                <label for="member-name" class="col-form-label">Kullanıcı Türü</label>
                @Html.DropDownListFor(m => m.kartVerisi.i_kullaniciTuruID, kullaniciTuru, "Lütfen Seçiniz", new { @class = "form-control select2", id = "Kullanıcı Türü" })
            </div>


            @Html.HiddenFor(model => model.kartVerisi.kullaniciID)
           
        </div>
        <hr />
        <button type="button" onclick="ekle()" id="btnKaydet" class="btn btn-success" data-bs-toggle="modal">
            Kaydet
        </button>
    </div>
</form>
<script>
    function ekle() {
        var valdata = $("#formKayit").serialize();
        console.table(valdata);
        $.ajax({
            url: "/Kullanici/Kaydet/",
            type: "Post",
            data: valdata,
            contentType: "application/x-www-form-urlencoded; charset=UTF-8",
            dataType: "json",
            success: function (response) {
                if (!response.success) {
                    Swal.fire(
                        'Hata',
                        response.message,
                        'error'
                    );
                    return false;
                }
                else {
                    Swal.fire(
                        'Başarılı',
                        response.message,
                        'success'
                    ).then(function () {
                        var deger = String(document.getElementById("yenimi").value);
                        if (deger == "True") {
                            window.location.reload();
                        }
                    })
                }
            }
        });
    }
</script>
