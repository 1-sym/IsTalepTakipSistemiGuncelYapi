
@using IsTakipSistemi.Data;
@model IsTakipSistemi.Models.PersonelModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h1 style="color:brown">Personel</h1>

<form id="formKayit" name="formKayit" autocomplete="off">
    @{

        <i style="float: left; width: 50%; color: white; ">

            <button type="button" class="btn btn-success btn-rounded waves-effect waves-light " onclick="kartAc(0);return false;">
                <i class="mdi mdi-plus me-1"></i>
                Yeni Personel Ekle
            </button>



        </i>
        <i style="float: right; width: 50%; text-align: right; color: white; ">

            <button type="button" class="btn btn-danger btn-rounded waves-effect waves-light" onclick="sil(); return fals;">
                <i class="mdi mdi-minus me-1"></i>
                Seçilen Kayıtları Sil
            </button>

        </i>
        <div style="float: left; width: 100%; height:30px;  "></div>
        <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
            <thead>
                <tr>
                    <th> </th>
                    <th>Ad-Soyad</th>
                    <th>TC No</th>
                    <th>Telefon</th>
                    <th>Birim</th>
                    <th>İzinli mi?</th>
                    <th>Giriş Tarihi</th>
                    <th>Çıkış Tarihi</th>
                    <th>Kullanıcı Türü</th>

                    <th>
                        Güncelle
                    </th>
                </tr>
            </thead>
            <tbody>
                @{
                    List<PersonelAYRINTI> veri = Model.dokumVerisi;
                    foreach (var satir in veri)
                    {
                        <tr row_id="@satir.personelID.ToString()">
                            <td>
                                <input type="checkbox" class="checkBox"
                                       value="@satir.personelID" />
                            </td>
                            <th>@satir.adi @satir.soyadi</th>
                            <th>@satir.TcNo</th>
                            <th>@satir.telefon</th>

                            <th>@satir.birimAdi</th>
                            <th>@satir.izinlimi</th>
                            <th>@satir.girisTarihi</th>
                            <th>@satir.ayrilisTarihi</th>
                            <th>@satir.kullaniciTuru</th>

                            <td>
                                <a class="btn btn-outline-secondary btn-sm edit" onclick="kartAc(@satir.personelID); return false;" style="color: #ffffff !important; background-color: #ffae00; border-color: #ffae00; " title="Edit">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</form>
<script>
    function kartAc(id) {
        window.location.href = "/Personel/Kart/" + id;
    }
    function sil() {
        var selectedIDs = new Array();
        $('input:checkbox.checkBox').each(function () {
            if ($(this).prop('checked')) {
                selectedIDs.push($(this).val());
            }
        });
        if (selectedIDs.length == 0) {
            alert('Lütfen silmek istediğiniz kayıtları seçiniz ')
            return;
        }
        var options = {};
        options.url = "/Personel/Sil?id=" + selectedIDs;
        options.type = "POST";
        options.data = JSON.stringify(selectedIDs);
        options.contentType = "application/json";
        options.dataType = "json";
        options.success = function (msg) {
            Swal.fire({
                position: "center-center", icon: "success",
                title: "Silme İşlemi Başarılı", showConfirmButton: !1, timer: 1750,
            });
            setTimeout(function () {
                window.location.reload(1);
            }, 1750);  //
        };
        options.error = function () {
            Swal.fire(
                'Hata',
                msg,
                'error'
            );
        };
        $.ajax(options);
        return false;
    }
</script>


